# Copy this file to .env and fill in the values. .env is gitignored.

# The MCP server base URL the dev proxy forwards to.
#   - Deployed:    https://youtubesearchandadd-production.up.railway.app
#   - Fully local: http://localhost:3000   (when running `npm start` in the repo root)
RAILWAY_URL=https://youtubesearchandadd-production.up.railway.app

# The bearer token for POST /credibility-render. This MUST match the server's
# OAUTH_CLIENT_SECRET environment variable. It stays on the Node side of the
# Vite dev server and is never shipped to the browser.
RENDER_TOKEN=
